# Public app port exposed on the host.
APP_HOST_PORT=8080

# PostgreSQL is always 5432 inside Docker; this is only the host port.
POSTGRES_HOST_PORT=15432
POSTGRES_DB=letf_lab
POSTGRES_USER=letf_lab
POSTGRES_PASSWORD=dev

# Must match the public URL used in the browser.
PUBLIC_ORIGIN=http://localhost:8080

# Auth
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_TOKEN_TTL_HOURS=24
AUTH_COOKIE_SECURE=false

# Seed is idempotent and runs at backend startup by default.
RUN_SEED=true
SEED_USER_EMAIL=admin@example.com
SEED_USER_PASSWORD=password

REFRESH_HOUR_ET=22
LOG_LEVEL=INFO

# Portfolio display currency. USD remains the internal base currency.
PORTFOLIO_BASE_CURRENCY=USD
PORTFOLIO_LOCAL_CURRENCY=BRL
PORTFOLIO_LOCAL_FX_TICKER=BRL=X
PORTFOLIO_LOCAL_FX_INVERT=false
PORTFOLIO_LOCALE=pt-BR

# Optional AI CLI integration. The backend image includes opencode.
AI_CLI_COMMAND=opencode
AI_CLI_MODEL=openai/gpt-5.4-mini-fast
AI_CLI_TIMEOUT_S=60
AI_CLI_PROMPTS_DIR=prompts
ANTHROPIC_API_KEY=
