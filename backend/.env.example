# Postgres is the supported setup. Provision the role + database against
# your local Postgres instance with `make db-create` (uses sudo -u postgres).
# SQLite remains as a fallback for quick offline dev.
DATABASE_URL=postgresql+psycopg://letf_lab:dev@localhost:5432/letf_lab
# DATABASE_URL=sqlite:///../data/letf_lab.db

PRICE_CACHE_DIR=../data/prices
REFRESH_HOUR_ET=22
LOG_LEVEL=INFO
API_PORT=8001
ALLOW_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Portfolio display currency. USD remains the internal base currency.
PORTFOLIO_BASE_CURRENCY=USD
PORTFOLIO_LOCAL_CURRENCY=BRL
PORTFOLIO_LOCAL_FX_TICKER=BRL=X
PORTFOLIO_LOCAL_FX_INVERT=false
PORTFOLIO_LOCALE=pt-BR

# Auth
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_TOKEN_TTL_HOURS=24
# Set to true behind HTTPS.
AUTH_COOKIE_SECURE=false

# Optional — daily AI report generation. Leave empty to disable.
ANTHROPIC_API_KEY=
