# Pick one — Postgres is the supported production setup; SQLite is fine for
# offline dev. The docker-compose.yml at the repo root provides the Postgres
# service that the URL below points to.
DATABASE_URL=postgresql+psycopg://ai_swing:dev@localhost:5432/ai_swing
# DATABASE_URL=sqlite:///../data/ai_swing.db

PRICE_CACHE_DIR=../data/prices
REFRESH_HOUR_ET=22
LOG_LEVEL=INFO
ALLOW_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Auth
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=change-me-to-a-long-random-string
AUTH_TOKEN_TTL_HOURS=24
AUTH_COOKIE_SECURE=false  # set to true behind HTTPS

# Optional — daily AI report generation. Leave empty to disable.
ANTHROPIC_API_KEY=
